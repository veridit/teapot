# Ignore Aider AI tool files
.aider*
!.aider.conf.yml
!.aiderignore
# Ignore build files generated with `cmake .`
/src/CMakeFiles/*
/src/CMakeCache.txt
/src/CPackConfig.cmake
/src/CPackSourceConfig.cmake
/src/Makefile
/src/cmake_install.cmake
/src/config.h
# Ignore built files
/src/libteapotlib.a
/src/teapot
/src/teapot.lyx
# Ignore rust build files
/target
# Ignore Claude Code local settings
.claude/
